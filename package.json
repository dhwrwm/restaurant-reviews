{
  "name": "dhwrwm-basumatary",
  "private": true,
  "packageManager": "pnpm@8.6.2",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "format": "prettier --write .",
    "prepare": "husky",
    "db:generate": "pnpm --filter api db:generate",
    "db:migrate": "pnpm --filter api db:migrate",
    "db:seed": "pnpm --filter api db:seed",
    "db:studio": "pnpm --filter api db:studio"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "turbo": "^2.10.3"
  },
  "lint-staged": {
    "apps/api/**/*.{ts,tsx,js,jsx}": "pnpm --filter api exec eslint --fix",
    "apps/web/**/*.{ts,tsx,js,jsx}": "pnpm --filter web exec eslint --fix",
    "apps/docs/**/*.{ts,tsx,js,jsx}": "pnpm --filter docs exec eslint --fix",
    "*.{ts,tsx,js,jsx,json,md,yml,yaml}": "prettier --write"
  },
  "pnpm": {
    "overrides": {
      "@types/react": "^19.2.17",
      "@types/react-dom": "^19.2.3"
    }
  }
}
