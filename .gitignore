# dependencies
node_modules

# this workspace uses pnpm exclusively; other lockfiles indicate an
# accidental `npm install`/`yarn install` and should not be committed
package-lock.json
yarn.lock

# build output
.next
dist
out
build

# Render packages/deploys its build artifact based on this file, so the
# actual apps/api and packages/types build outputs must stay un-ignored
# even though they're still never committed to git.
!apps/api/dist/
!apps/api/dist/**
!packages/types/dist/
!packages/types/dist/**

# env files
.env
.env*.local

# testing
coverage

# turborepo
.turbo/

# misc
.DS_Store
*.pem
*.tsbuildinfo
next-env.d.ts

# logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# vercel
.vercel
node_modules
